# AlarmMini root environment file (copy to .env and fill real values)
# This is the ONLY .env file expected by project scripts.

# Build mode for web assets: local | release
ALARMMINI_CONFIG_MODE=local

# Links shown in firmware web UI and installer UI
ALARMMINI_SUPPORT_URL=https://send.monobank.ua/jar/2PMhPjRk9j
ALARMMINI_TELEGRAM_URL=https://t.me/+j3zFZHE5gGoyNGYy

# Default MQTT values injected into release config template (work_data/config.example.json)
ALARMMINI_MQTT_HOST=mqtt.example.com
ALARMMINI_MQTT_TOPIC=ukraine/alarm/map/full
ALARMMINI_MQTT_USER=mqtt_user
ALARMMINI_MQTT_PASS=change_me

# Installer GitHub source
NEXT_PUBLIC_GITHUB_OWNER=WebDev-Den
NEXT_PUBLIC_GITHUB_REPO=AlarmMini

# Installer links (fallback to ALARMMINI_* links if empty)
NEXT_PUBLIC_SUPPORT_URL=
NEXT_PUBLIC_TELEGRAM_URL=

# Node-RED / external integration (kept here for centralized secrets management)
# server.json intentionally not auto-rewritten.
ALARMMINI_WEBHOOK_URL=https://alarm.web-dev.uno/webhook/action/
ALARMMINI_ALERTS_API_URL=https://api.ukrainealarm.com/api/v3/alerts
ALARMMINI_API_AUTH_TOKEN=replace_me
ALARMMINI_MQTT_BROKER=46.63.78.202
ALARMMINI_MQTT_PORT=1883
ALARMMINI_MQTT_USERNAME=
ALARMMINI_MQTT_PASSWORD=
