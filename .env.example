# AlarmMini root environment file (copy to .env and fill values)
# This is the ONLY .env file expected by project scripts.

# Build mode for web assets: local | release
ALARMMINI_CONFIG_MODE=local

# Links shown in firmware web UI and installer UI
ALARMMINI_SUPPORT_URL=https://send.monobank.ua/jar/2PMhPjRk9j
ALARMMINI_TELEGRAM_URL=https://t.me/+j3zFZHE5gGoyNGYy

# Optional explicit release-safe MQTT defaults for config.example placeholders.
# If not set, release build falls back to non-sensitive generic values.
ALARMMINI_RELEASE_MQTT_HOST=mqtt.example.com
ALARMMINI_RELEASE_MQTT_TOPIC=ukraine/alarm/map/full
ALARMMINI_RELEASE_MQTT_USER=mqtt_user
ALARMMINI_RELEASE_MQTT_PASS=change_me

# Installer GitHub source
NEXT_PUBLIC_GITHUB_OWNER=WebDev-Den
NEXT_PUBLIC_GITHUB_REPO=AlarmMini

# Installer links (fallback to ALARMMINI_* links if empty)
NEXT_PUBLIC_SUPPORT_URL=
NEXT_PUBLIC_TELEGRAM_URL=
